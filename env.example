DB_HOST=localhost
DB_PORT=5432
DB_NAME=cafe_bakery_db
DB_USER=postgres
DB_PASSWORD=postgres123
PORT=5000
NODE_ENV=development

# ---------------------------------------------------------------------------
# Inventory domain (Phase 0/1) — centralized LAN PostgreSQL
# ---------------------------------------------------------------------------
# Master switch: 'pg' enables the PostgreSQL-backed inventory module and
# mounts /api/inv/*. 'json' (or unset) leaves the legacy JSON paths untouched.
INVENTORY_BACKEND=json

# Business timezone for snapshots / daily boundaries / display.
INVENTORY_TZ=Africa/Addis_Ababa

# Pool / safety tuning for the centralized server.
INVENTORY_PG_POOL_MAX=25
INVENTORY_PG_STATEMENT_TIMEOUT_MS=15000
INVENTORY_PG_IDLE_TXN_TIMEOUT_MS=10000

# Permanent attachment storage root (DB stores metadata + checksum only).
INVENTORY_STORAGE_ROOT=./data/inventory_attachments

# Backup destinations (scripts/inventory/backup.js).
INVENTORY_BACKUP_DIR=./backups/inventory
INVENTORY_BACKUP_OFFSITE_DIR=
# Path to pg_dump if not on PATH (e.g. C:\Program Files\PostgreSQL\16\bin\pg_dump.exe)
PG_DUMP_PATH=pg_dump
